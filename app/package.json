{
  "name": "matrix-construction-set",
  "productName": "Matrix Construction Set",
  "version": "1.1.0",
  "description": "Create and visualize Shadowrun matrix environments — modern Electron rebuild of the classic Cyberspace/Matrix package (VB3, 2000) by Stefan Markgraf.",
  "license": "GPL-2.0",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "start": "electron .",
    "dist": "vite build && electron-builder --win"
  },
  "build": {
    "appId": "net.sourceforge.cyberspace.mated",
    "files": [
      "dist/**",
      "electron/**"
    ],
    "extraResources": [
      {
        "from": "examples",
        "to": "examples"
      }
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "portable",
        "nsis"
      ]
    }
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.184.0"
  }
}
