Sub Spin1_SpinDown (Index As Integer)
  Dim wold%

  wold = Val(Text2(Index).Text)
  If wold > 1 And Index <> 9 And Index <> 10 Then
    Select Case Index
      Case 0: decker.body = decker.body - 1
      Case 1: decker.quickness = decker.quickness - 1
      Case 2: decker.strength = decker.strength - 1
      Case 3: decker.charisma = decker.charisma - 1
      Case 4: decker.intelligence = decker.intelligence - 1
      Case 5: decker.willpower = decker.willpower - 1
      Case 6: decker.reactdice = decker.reactdice - 1
      Case 7: decker.reaction = decker.reaction - 1
      Case 8: decker.hackingpool = decker.hackingpool - 1
      Case 9: decker.karma = decker.karma - 1
      Case 10: decker.team = decker.team - 1
      Case 11: decker.computer = decker.computer - 1
    End Select
    UpdateDecker
    dirtyflag = True
  ElseIf wold > 0 And (Index = 9 Or Index = 10) Then
    Select Case Index
      Case 9: decker.karma = decker.karma - 1
      Case 10: decker.team = decker.team - 1
    End Select
    UpdateDecker
    dirtyflag = True
  End If
End Sub

Sub Spin1_SpinUp (Index As Integer)
  Dim wold%

  wold = Val(Text2(Index).Text)
  Select Case Index
    Case 0: decker.body = decker.body + 1
    Case 1: decker.quickness = decker.quickness + 1
    Case 2: decker.strength = decker.strength + 1
    Case 3: decker.charisma = decker.charisma + 1
    Case 4: decker.intelligence = decker.intelligence + 1
    Case 5: decker.willpower = decker.willpower + 1
    Case 6: decker.reactdice = decker.reactdice + 1
    Case 7: decker.reaction = decker.reaction + 1
    Case 8: decker.hackingpool = decker.hackingpool + 1
    Case 9: decker.karma = decker.karma + 1
    Case 10: decker.team = decker.team + 1
    Case 11: decker.computer = decker.computer + 1
  End Select
  UpdateDecker
  dirtyflag = True

End Sub

Sub Text1_Change ()
  dirtyflag = True
