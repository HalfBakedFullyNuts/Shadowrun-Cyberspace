Sub CheckStatus_Click (Index As Integer, Value As Integer)
  Rem Click on Damage Status Checkboxes
  Dim i%
  
  If Index < 10 Then
    If Value = True Then
      For i = Index - 1 To 0 Step -1
        If CheckStatus(i).Value = False Then
          CheckStatus(i).Value = True
        End If
      Next i
    Else
      For i = 9 To Index + 1 Step -1
        If CheckStatus(i).Value = True Then
          CheckStatus(i).Value = False
        End If
      Next i
    End If
    For i = 0 To 9
      If CheckStatus(i).Value = False Then Exit For
    Next i
    decker.damage_stun = i

  ElseIf Index < 20 Then
    If Value = True Then
      For i = Index - 1 To 10 Step -1
        If CheckStatus(i).Value = False Then
          CheckStatus(i).Value = True
        End If
      Next i
    Else
      For i = 19 To Index + 1 Step -1
        If CheckStatus(i).Value = True Then
          CheckStatus(i).Value = False
        End If
      Next i
    End If
    For i = 10 To 19
      If CheckStatus(i).Value = False Then Exit For
    Next i
    decker.damage_phys = i - 10
  End If

  dirtyflag = True
  Debug.Print "Damage="; decker.damage_stun, decker.damage_phys
End Sub

Sub Form_Load ()
  Dim a As String

  padclearlen = 2
  padwidth = 24
  m_new_click

  inifile$ = GetPathes()
  If TestPathes(inifile$) = False Then End
  SetPathes (inifile$)
  a$ = ReadDataIni(inifile$, "Cyberspace Program", "DefaultDecker")
  If Len(a$) > 0 Then
    On Error Resume Next
    LoadDecker (a$)
  End If
End Sub

Sub LoadDecker (c$)
  Dim a$
  Dim i%
  
  ' Read deck statistics
  
  decker.name = ReadDataIni(c$, "Character", "Name")
  a$ = "Attributes"
  decker.body = Val(ReadDataIni(c$, a$, "Body"))
  decker.quickness = Val(ReadDataIni(c$, a$, "Quickness"))
  decker.strength = Val(ReadDataIni(c$, a$, "Strength"))
  decker.charisma = Val(ReadDataIni(c$, a$, "Charisma"))
  decker.intelligence = Val(ReadDataIni(c$, a$, "Intelligence"))
  decker.willpower = Val(ReadDataIni(c$, a$, "Willpower"))
  decker.damage_stun = Val(ReadDataIni(c$, a$, "Stun Damage"))
  decker.damage_phys = Val(ReadDataIni(c$, a$, "Phys Damage"))
  
  i = decker.damage_stun
  If decker.damage_stun > 0 Then
    If CheckStatus(decker.damage_stun - 1).Value = True Then
      CheckStatus(i - 1).Value = False
    End If
    CheckStatus(i - 1).Value = True
  Else
    CheckStatus(0).Value = False  ' acts as click
  End If
  i = decker.damage_phys
  If i > 0 Then
    If CheckStatus(i + 10 - 1).Value = True Then
      CheckStatus(i + 10 - 1).Value = False
    End If
    CheckStatus(i + 10 - 1).Value = True
    ' Call CheckStatus_Click(decker.damage_phys + 10 - 1, True)
  Else
    CheckStatus(10).Value = False ' acts as click
  End If

  a$ = ReadDataIni(c$, "Attributes", "Reaction")
  decker.reaction = Val(a$)
  decker.reactdice = Val(Mid$(a$, InStr(a$, "+") + 1, 1))
  decker.hackingpool = Val(ReadDataIni(c$, "Dice Pools", "Hacking"))
  decker.karma = Val(ReadDataIni(c$, "Dice Pools", "Karma"))
  decker.team = Val(ReadDataIni(c$, "Dice Pools", "Team"))

  skilltype = "Decking"
  i = Val(ReadDataIni(c$, "Skills", "Computer/Software/Decking"))
  If i = 0 Then
    skilltype = "Software"
    i = Val(ReadDataIni(c$, "Skills", "Computer/Software"))
    If i = 0 Then
      skilltype = "Computer"
      i = Val(ReadDataIni(c$, "Skills", "Computer"))
      If i = 0 Then
        skilltype = "None"
      End If
    End If
  End If
  decker.computer = i
  
  Text1.Text = decker.name
  UpdateDecker
  dirtyflag = False

End Sub

