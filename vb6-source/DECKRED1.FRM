End Sub

Sub Text2_Change (Index As Integer)
  If Index >= 0 Then
    Select Case Index
      Case 0: decker.body = Val(Text2(Index).Text)
      Case 1: decker.quickness = Val(Text2(Index).Text)
      Case 2: decker.strength = Val(Text2(Index).Text)
      Case 3: decker.charisma = Val(Text2(Index).Text)
      Case 4: decker.intelligence = Val(Text2(Index).Text)
      Case 5: decker.willpower = Val(Text2(Index).Text)
      Case 6: decker.reactdice = Val(Text2(Index).Text)
            Text2(Index).Text = Format(decker.reactdice) & "D"
      Case 7: decker.reaction = Val(Text2(Index).Text)
      Case 8: decker.hackingpool = Val(Text2(Index).Text)
      Case 9: decker.karma = Val(Text2(Index).Text)
      Case 10: decker.team = Val(Text2(Index).Text)
      Case 11: decker.computer = Val(Text2(Index).Text)
    End Select
    dirtyflag = True
  End If

End Sub

Sub Text2_KeyPress (Index As Integer, KeyAscii As Integer)
  Dim nidx%
  
  If KeyAscii = 13 Then
    KeyAscii = 0
    Call Text2_Change(Index)
    nidx = Index + 1
    If nidx = 12 Then nidx = 0
    Text2(nidx).SetFocus
    UpdateDecker
  End If
End Sub

Sub UpdateDecker ()
  Dim w%

  Text2(0).Text = Format(decker.body)
  Text2(1).Text = Format(decker.quickness)
  Text2(2).Text = Format(decker.strength)
  Text2(3).Text = Format(decker.charisma)
  Text2(4).Text = Format(decker.intelligence)
  Text2(5).Text = Format(decker.willpower)
  Text2(6).Text = Format(decker.reactdice) & "D"
  Text2(7).Text = Format(decker.reaction)
  If decker.hackingpool = 0 Then
    Text2(8).Text = "auto"
  Else
    Text2(8).Text = Format(decker.hackingpool)
  End If
  Text2(9).Text = Format(decker.karma)
  Text2(10).Text = Format(decker.team)
  Text2(11).Text = Format(decker.computer)
  If decker.body <= 0 Then pad.Caption = "Body must be >= 1"
  If decker.quickness <= 0 Then pad.Caption = "Quickness must be >= 1"
  If decker.strength <= 0 Then pad.Caption = "Strength must be >= 1"
  If decker.charisma <= 0 Then pad.Caption = "Charisma must be >= 1"
  If decker.intelligence <= 0 Then pad.Caption = "Intelligence must be >= 1"
  If decker.willpower <= 0 Then pad.Caption = "Willpower must be >= 1"
  If decker.reactdice <= 0 Then pad.Caption = "Initiative die must be >= 1"
  If decker.reaction <= 0 Then pad.Caption = "Reaction must be >= 1"
  If decker.computer <= 0 Then pad.Caption = "Computer Skill must be >= 1"

End Sub

