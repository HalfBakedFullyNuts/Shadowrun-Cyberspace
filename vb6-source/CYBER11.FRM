Sub Form_Activate ()
  Dim i%
  
  For i = 0 To 5
    Text1(i).Text = "0"
  Next i

End Sub

Sub Picture1_MouseDown (button As Integer, Shift As Integer, X As Single, y As Single)
  Dim i%, n%
  Dim a$
  
  i = Fix(y)
  ' Debug.Print "Pressed ", i
  n = Val(Format(Text1(i).Text))
  If button = 1 Then
    n = n + 1
  Else
    n = n - 1
  End If
  If n < 0 Then n = 0
  ' Debug.Print "New Value "; n
  Text1(i).Text = Trim$(" " & n)

End Sub

