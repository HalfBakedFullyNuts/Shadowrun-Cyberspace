  Dim a$, p$
  Dim r%

  a$ = b$
  p$ = GetWord(a$, "-")
  r = Val(a$)
  If FitStorage(p$, 0, r) = False Then
    Rem load program anyway!
  End If

End Sub

Sub Check3D1_Click (index As Integer, Value As Integer)
  Dim i%
  Dim a$, p$

  If Check3D1(index).Value = False Then
    Check3D1(index).Caption = "No"
    Select Case index
      Case 0: deck.satuplink = 0
      Case 1: deck.purecyber = 0
      Case 2: deck.realfilter = 0
    End Select
  Else
    Check3D1(index).Caption = "Yes"
    Select Case index
      Case 0:
        deck.satuplink = 1   ' Add Satlink-1 if not already there
        For i = 0 To List1.ListCount - 1
          a$ = List1.List(i)
          p$ = UCase$(GetWord(a$, "-"))
          If p$ = "SATLINK" Then Exit For
        Next i
        If i = List1.ListCount Then
          Addprogram ("Satlink-1")
        End If
      Case 1: deck.purecyber = 1
      Case 2: deck.realfilter = 1
    End Select
  End If
  UpdateDeck
  dirtyflag = True
End Sub

Sub CheckStatus_Click (index As Integer, Value As Integer)
  Dim i As Integer
  
  If Value = True Then
    For i = index - 1 To 0 Step -1
      If CheckStatus(i).Value = False Then
        CheckStatus(i).Value = True
      End If
    Next i
  Else
    For i = 9 To index + 1 Step -1
      If CheckStatus(i).Value = True Then
        CheckStatus(i).Value = False
      End If
    Next i
  End If
  For i = 0 To 9
    If CheckStatus(i).Value = False Then Exit For
  Next i
  deck.damage = i
  dirtyflag = True
End Sub

