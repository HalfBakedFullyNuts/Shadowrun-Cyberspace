Function FillProglist () As Integer
  Dim i%, m%

  m = List1.ListCount
  If m > 0 Then
    ReDim proglist$(m - 1)
    For i = 0 To m - 1
      proglist$(i) = List1.List(i)
    Next i
  Else
    ReDim proglist$(0)
    proglist$(0) = ""
  End If
  FillProglist = m
End Function

Function FindProg (Liste As ListBox, p$) As Integer
  Rem Search program in liste and returns listindex
  Dim i%, ret%
  Dim a$, b$

  ret = -1
  For i = 0 To Liste.ListCount - 1
    a$ = Liste.List(i)
    If UCase$(Strwobrackets(GetWord(a$, "-"))) = p$ Then ret = i
  Next i

  FindProg = ret

End Function

Function FitStorage (prog$, rating%, addrate%) As Integer
  Rem Tests if program fits storage in new rating and
  Rem calculates the size taken compressor into account.
  Rem addrate may be negative.
  Rem rating may be 0, then program is added to the storage list.
  Rem if prog$ = "" --> Only updating bars.

  Dim a$, p$, s$
  Dim i%, r%, size%, ret%

  ret = True
  If Len(prog$) > 0 Then
    If rating + addrate <= 0 Then
      Rem rating + addrate = 0  ---> Erase Program
      
      If List1.ListIndex >= 0 Then
        a$ = List1.List(List1.ListIndex)
        p$ = GetWord(a$, "-")
        If p$ = "Compressor" Then
          deck.compressed = 0
        End If
        List1.RemoveItem List1.ListIndex
        dirtyflag = True
      End If
  
    ElseIf rating = 0 Then
      Rem rating = 0 (and addrate > 0) ---> Add new Program
    
      size = CalcProgsize(prog$, rating + addrate)
      If UCase$(prog$) = "ANALYSE" Then prog$ = "Analyze"
      a$ = prog$ & "-" & Format(rating + addrate) & " [" & Format(size) & "Mp]"
      List1.AddItem a$
      dirtyflag = True

    Else
      Rem ---> Change rating of program
    
      size = CalcProgsize(prog$, rating + addrate)
      If List1.ListIndex >= 0 Then
        size = CalcProgsize(prog$, rating + addrate)
        If prog$ = "Compressor" Then
          deck.compressed = rating + addrate
        End If
        size = CalcProgsize(prog$, rating + addrate)
        a$ = prog$ & "-" & Format(rating + addrate) & " [" & Format(size) & "Mp]"
        List1.List(List1.ListIndex) = a$
        dirtyflag = True
      End If
    End If
  End If
  
  
  deck.storageprogmem = 0
  For i = 0 To List1.ListCount - 1
    a$ = List1.List(i)
    p$ = GetWord(a$, "-")
    r = Val(a$)
    size = CalcProgsize(p$, r)
    If p$ = "Compressor" Then
      deck.compressed = r
      s$ = Format(size)
    Else
      If deck.compressed > 0 And size <= 100 * deck.compressed Then
        s$ = Format(Int(size / 2 + .6))
      ElseIf deck.compressed > 0 Then
        NewPad ("Compressor unable to compress size of " & p$ & "-" & Format(r) & " program.")
        s$ = Format(size)
      Else
        s$ = Format(size)
      End If
    End If
    deck.storageprogmem = deck.storageprogmem + Val(s$)
    a$ = p$ & "-" & Format(r) & " [" & s$ & "Mp]"
    List1.List(i) = a$
    If deck.storageprogmem > deck.storagemem Then
      NewPad ("Storage memory exhausted by " & a$ & ".")
      ret = False
    End If
  Next i
  UpdateMemoryStatus
  If deck.compressed > 0 Then
    Compress_label.BackColor = GREEN
  Else
    Compress_label.BackColor = LAMPGRAY
  End If
  FitStorage = ret
  

End Function

