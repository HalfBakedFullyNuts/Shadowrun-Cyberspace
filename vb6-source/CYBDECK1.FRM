Sub LoadDeckWrap (Filename$)
    Dim i As Integer
    Dim no As Integer
    
    List1.Clear
    no = LoadDeck(Filename$)
    For i = 0 To no - 1
      Addprogram (proglist$(i))
    Next i
    Text1.Text = deck.model
    If deck.damage > 0 Then
      i = deck.damage
      If CheckStatus(i - 1).Value = True Then
        CheckStatus(i - 1).Value = False
      End If
      CheckStatus(i - 1).Value = True
    Else
      CheckStatus(0).Value = False
    End If

    For i = 0 To 4
      deck.add(i) = 0       ' Erase Persona Program Add's, Damage, changes
      deck.dam(i) = 0
      deck.chg(i) = 0
    Next i
    deck.mpcp = deck.oripp(4)    ' undo changes of damage and add's
    deck.bod = deck.oripp(0)
    deck.evasion = deck.oripp(1)
    deck.masking = deck.oripp(2)
    deck.sensor = deck.oripp(3)
    UpdateDeck
    If deck.satuplink <> 0 Then
      Check3D1(0).Value = True
    Else
      Check3D1(0).Value = False
    End If
    If deck.purecyber <> 0 Then
      Check3D1(1).Value = True
    Else
      Check3D1(1).Value = False
    End If
    If deck.realfilter <> 0 Then
      Check3D1(2).Value = True
    Else
      Check3D1(2).Value = False
    End If
    UpdateMemoryStatus
End Sub

