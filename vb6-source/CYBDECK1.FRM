Sub UpdateMemoryStatus ()
  Dim w%
  Storage_label = Format(deck.storageprogmem) & "Mp"
  If deck.storageprogmem <= deck.storagemem Then
    If deck.storagemem > 0 Then
      Storage.FloodPercent = 100# * deck.storageprogmem / deck.storagemem
    End If
  Else
    Storage.FloodPercent = 100
  End If
End Sub

