Sub Spin1_SpinDown (index As Integer)
  Dim wold%

  wold = Val(Text2(index).Text)
  If wold > 0 Then
    Select Case index
      Case 0: deck.oripp(4) = deck.oripp(4) - 1
      Case 1: deck.oripp(0) = deck.oripp(0) - 1
      Case 2: deck.oripp(1) = deck.oripp(1) - 1
      Case 3: deck.oripp(2) = deck.oripp(2) - 1
      Case 4: deck.oripp(3) = deck.oripp(3) - 1
      Case 5: deck.load = deck.load - 1
      Case 6: deck.io = deck.io - 1
      Case 7: deck.hardening = deck.hardening - 1
      Case 8: deck.activemem = deck.activemem - 1
      Case 9: deck.storagemem = deck.storagemem - 1
      Case 10: deck.response = deck.response - 1
    End Select
    UpdateDeck
    dirtyflag = True
  End If
End Sub

Sub Spin1_SpinUp (index As Integer)
  Dim wold%

  wold = Val(Text2(index).Text)
  Select Case index
    Case 0: deck.oripp(4) = deck.oripp(4) + 1
    Case 1: deck.oripp(0) = deck.oripp(0) + 1
    Case 2: deck.oripp(1) = deck.oripp(1) + 1
    Case 3: deck.oripp(2) = deck.oripp(2) + 1
    Case 4: deck.oripp(3) = deck.oripp(3) + 1
    Case 5: deck.load = deck.load + 1
    Case 6: deck.io = deck.io + 1
    Case 7: deck.hardening = deck.hardening + 1
    Case 8: deck.activemem = deck.activemem + 10
    Case 9: deck.storagemem = deck.storagemem + 50
    Case 10: deck.response = deck.response + 1
  End Select
  UpdateDeck
  wold = TestDeck(deck, FillProglist())
  dirtyflag = True
End Sub

